// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`test framework convertor - Perl test-more matches golden snapshot (setup + provider) 1`] = `
"use strict;
use warnings;
use Test::More;

sub map_row_under_test {
    my ($row) = @_;
    # Example: return normalize_person($row);
    return $row; # replace with your system-under-test call
}

my $setup = {};

sub row_provider {
    return [
  {'Name' => 'Connie', 'Age' => 21},
  {'Name' => 'Miles', 'Age' => 34}
];
}

my $rows = row_provider();

foreach my $row (@$rows) {
    my $expected = $row;
    my $actual = map_row_under_test($row);
    is_deeply($actual->{\\"Name\\"}, $expected->{\\"Name\\"}, 'row Name');
    is_deeply($actual->{\\"Age\\"}, $expected->{\\"Age\\"}, 'row Age');
}

done_testing();"
`;
